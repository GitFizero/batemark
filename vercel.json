{
  "redirects": [
    { "source": "/feed/", "destination": "/blog", "permanent": true },
    { "source": "/comments/feed/", "destination": "/blog", "permanent": true },
    { "source": "/home/", "destination": "/", "permanent": true },
    { "source": "/biography/", "destination": "/", "permanent": true },
    { "source": "/wp-admin/:path*", "destination": "/admin", "permanent": true },
    { "source": "/wp-login.php", "destination": "/admin/login", "permanent": true },
    { "source": "/blog/la-agence-immobiliere", "destination": "/blog/ia-agence-immobiliere", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
